//father and mother definition
void askColor(int& father, int& mother){
    //father
    do{
        cout<<"Does the father have...\n";
        cout<<"1) Normal vision\n";
        cout<<"2) Is colorblind\n";
        cout<<"Answer: ";
        
        while (!(cin>>father)) {
            error();
            cout<<"Does the father have...\n";
            cout<<"1) Normal vision\n";
            cout<<"2) Is colorblind\n";
            cout<<"Answer: ";
        }
            
        if (father<1||father>2) {
        cout<< "Error. Please try again.\n\n";
        }
    }while (father<1||father>2);

    //mother
    cout<<"\n";
    do{
        cout<<"Does the mother have...\n";
        cout<<"1) Normal vision\n";
        cout<<"2) Is colorblind\n";
        cout<<"3) Is a carrier\n";
        cout<<"Answer: ";
        
        while (!(cin>>mother)) {
            error();
            cout<<"Does the mother have...\n";
            cout<<"1) Normal vision\n";
            cout<<"2) Is colorblind\n";
            cout<<"3) Is a carrier\n";
            cout<<"Answer: ";
        }
        
        if (mother<1||mother>3) {
        cout<< "Error. Please try again.\n\n";
        }
    }while (mother<1||mother>3);
}

//error definition
void error(){
if (cin.fail()) {
        cin.clear();                
        cin.ignore(1000, '\n');     
        cout << "Error. Please try again.\n\n";
    }
}

//punnett definition
void punnett(int& father, int& mother) {
    cout<<"\nNOTE: XX is FEMALE, XY is MALE, C is COLORBLINDNESS.\n";
    cout<<"\nPunnett square:\n";
if ((father==1)&&(mother==1)){  
    cout<<"-------------------------------------------\n";
